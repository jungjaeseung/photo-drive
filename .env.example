# Web app
NEXT_PUBLIC_BASE_PATH=/photos
ELASTICSEARCH_URL=http://localhost:9200
REDIS_URL=redis://localhost:6379
STORAGE_ROOT=./storage

# Auth (NextAuth) — openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true
# NextAuth 공개 URL (basePath 포함) — https://your-host/photos
AUTH_URL=

# 초기 사용자 시드 (선택, 1회): pnpm --filter @photo-drive/web es:seed-users
# AUTH_BOOTSTRAP_USERS='[{"id":"user1","password":"your-password","name":"이름"}]'

# Docker (호스트 스토리지 경로)
STORAGE_HOST_PATH=/mnt/extra/photo-drive

# Web Push (VAPID) — npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
PUBLIC_APP_URL=https://3harang.ddns.net
